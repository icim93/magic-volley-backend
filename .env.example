# Copia questo file in ".env" e personalizza i valori prima di avviare in produzione.

# Chiave segreta per firmare i JWT - GENERANE UNA NUOVA E CASUALE, non usare questo valore.
SECRET_KEY=cambia-questa-chiave-con-una-stringa-lunga-e-casuale

# Stringa di connessione al database.
# Sviluppo locale (default se non impostata): sqlite:///./magicvolley.db
# Produzione (es. PostgreSQL su Render):
# DATABASE_URL=postgresql://utente:password@host:5432/nome_db

# Origini autorizzate per le richieste CORS dal frontend (separate da virgola)
ALLOWED_ORIGINS=http://localhost:5173,https://magicvolleyadelfia.it
